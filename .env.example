# Groq API key (free tier)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# Groq model to use. Default: llama-3.3-70b-versatile (12K TPM)
# Other options: llama-3.1-8b-instant (6K), qwen/qwen3.6-27b (8K), openai/gpt-oss-120b (30K)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: override Invidious instances (comma separated, first wins)
# Default: https://yewtu.be,https://invidious.fdn.fr,https://invidious.protokolla.fi
INVIDIOUS_INSTANCES=https://yewtu.be,https://invidious.fdn.fr,https://invidious.protokolla.fi
